{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "guayand0.speedrun-splits",
	"name": "speedrun-splits",
	"version": "v1.0.0",
	"developer": "Guayand0",
	"description": "Adds a speedrun timer with checkpoint splits, PB tracking, and in-pause split record management for platformer levels.",
	"repository": "https://github.com/Guayand0/GeometryDash-Mod-SpeedrunSplits",
	"links": {
		"source": "https://github.com/Guayand0/GeometryDash-Mod-SpeedrunSplits",
		"community": "https://discord.gg/RDaTJqdwMS"
	},
	"tags": [
		"utility",
		"gameplay",
		"interface",
		"platformer"
	],
	"settings": {
		"general-title": {
			"type": "title",
			"name": "General"
		},
		"mod-enabled": {
			"type": "bool",
			"name": "Enable Mod",
			"description": "Enable or disable the splits system completely",
			"default": true
		},
		"show-timer": {
			"type": "bool",
			"name": "Show Timer",
			"description": "Show the global timer on screen",
			"default": true,
			"enable-if": "mod-enabled"
		},
		"timer-format": {
			"type": "string",
			"name": "Timer Format",
			"description": "Choose how the main timer is displayed",
			"default": "Hours / Minutes / Seconds / Milliseconds",
			"one-of": ["Hours / Minutes / Seconds / Milliseconds", "Seconds / Milliseconds"],
			"enable-if": "mod-enabled && show-timer"
		},
		"timer-decimals": {
			"type": "string",
			"name": "Timer Decimals",
			"description": "Choose whether the main timer shows 2 or 3 decimals",
			"default": "3",
			"one-of": ["2", "3"],
			"enable-if": "mod-enabled && show-timer"
		},
		"show-list": {
			"type": "bool",
			"name": "Show List",
			"description": "Show the checkpoint and split list",
			"default": true,
			"enable-if": "mod-enabled"
		},
		"ui-position": {
			"type": "string",
			"name": "Screen Position",
			"description": "Choose where the splits interface appears",
			"default": "Top Left",
			"one-of": ["Top Left", "Top Right", "Bottom Left", "Bottom Right"],
			"enable-if": "mod-enabled"
		},
		"appearance-title": {
			"type": "title",
			"name": "Appearance"
		},
		"font-scale": {
			"type": "float",
			"name": "Font Size",
			"description": "Scale of the timer and list text",
			"default": 0.4,
			"min": 0.3,
			"max": 1.2,
			"enable-if": "mod-enabled",
			"control": {
				"slider": true,
				"slider-step": 0.05,
				"arrows": true,
				"arrow-step": 0.05,
				"big-arrows": false,
				"input": false
			}
		},
		"line-spacing": {
			"type": "float",
			"name": "List Spacing",
			"description": "Vertical space between checkpoint rows",
			"default": 10.0,
			"min": 8.0,
			"max": 20.0,
			"enable-if": "mod-enabled && show-list",
			"control": {
				"slider": true,
				"slider-step": 1.0,
				"arrows": true,
				"arrow-step": 1.0,
				"big-arrows": false,
				"input": false
			}
		}
	},
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
	}
}
